{
  "version": "1.0.0",
  "title": "Feedback CTA",
  "description": "Dark-blue call-to-action strip inviting users to share feedback. Title, description, and a primary button.",
  "category": "custom",
  "source": {
    "path": "dist",
    "entry": "content.html"
  },
  "properties": [
    {
      "name": "title",
      "label": "Title",
      "type": "text",
      "default": "Have feedback about Gainsight University?",
      "rules": { "required": true, "maxLength": 160 }
    },
    {
      "name": "description",
      "label": "Description",
      "type": "text",
      "default": "We're always looking to improve. Tell us what's working and what's not."
    },
    {
      "name": "cta_label",
      "label": "Button label",
      "type": "text",
      "default": "Let Us Know"
    },
    {
      "name": "cta_url",
      "label": "Button link",
      "type": "text",
      "default": "#",
      "rules": { "required": true }
    },
    {
      "name": "cta_new_tab",
      "label": "Open link in new tab",
      "type": "toggle",
      "default": true
    }
  ]
}
