{
  "connectors": [
    {
      "name": "YouTube Pulse Playlist",
      "url": "https://www.googleapis.com/youtube/v3/playlistItems",
      "method": "GET",
      "permalink": "youtube-pulse-playlist",
      "query_parameters": [
        { "key": "part", "value": "snippet,contentDetails,status", "overridable": false },
        { "key": "maxResults", "value": "50", "overridable": true },
        { "key": "playlistId", "value": "PLB2Z_xLbXPiB91UH5KTm5wHoR9CsLDsaL", "overridable": true }
      ],
      "authentication": {
        "type": "apikey",
        "config": {
          "key": "key",
          "value": "{{ get_secret('youtube_api_key') }}",
          "in": "query"
        }
      }
    }
  ]
}
