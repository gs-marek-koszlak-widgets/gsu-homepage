{
  "version": "1.0.0",
  "title": "Announcement Bar",
  "description": "Configurable announcement bar with icon, title, description, and optional CTA. Use for advisories, welcome messages, or other top-of-page notices.",
  "category": "custom",
  "source": {
    "path": "dist",
    "entry": "content.html"
  },
  "properties": [
    {
      "name": "variant",
      "label": "Variant",
      "type": "select",
      "default": "info",
      "options": [
        { "label": "Info (blue)", "value": "info" },
        { "label": "Warning (red)", "value": "warning" },
        { "label": "Neutral (gray)", "value": "neutral" }
      ]
    },
    {
      "name": "icon_url",
      "label": "Icon URL (optional)",
      "type": "text",
      "default": ""
    },
    {
      "name": "title",
      "label": "Title",
      "type": "text",
      "default": "Welcome",
      "rules": { "required": true, "maxLength": 120 }
    },
    {
      "name": "description",
      "label": "Description",
      "type": "text",
      "default": ""
    },
    {
      "name": "cta_label",
      "label": "Button label (optional)",
      "type": "text",
      "default": ""
    },
    {
      "name": "cta_url",
      "label": "Button link (optional)",
      "type": "text",
      "default": ""
    },
    {
      "name": "cta_new_tab",
      "label": "Open link in new tab",
      "type": "toggle",
      "default": false
    }
  ]
}
